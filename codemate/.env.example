# --- LLM 云 API（W1 起） ---
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat              # 或 deepseek-coder

# --- LLM 本地（W2 起） ---
LOCAL_LLM_BASE_URL=http://localhost:8080  # llama.cpp server
LOCAL_LLM_MODEL=qwen2.5-coder-7b-q4_k_m

# --- 双轨切换策略（W6 起） ---
LLM_DEFAULT_BACKEND=deepseek              # deepseek | local
LLM_FALLBACK_BACKEND=local                # 主线失败时降级

# --- Embedding（W4 起） ---
EMBEDDING_BACKEND=local                   # local | openai
EMBEDDING_MODEL=BAAI/bge-m3               # 本地路径或 HF 名

# --- 向量库（W4 Chroma / W5 Milvus） ---
VECTOR_STORE=chroma                       # chroma | milvus
CHROMA_PERSIST_DIR=./data/chroma
MILVUS_HOST=localhost
MILVUS_PORT=19530

# --- 持久化（W6 起） ---
SQLITE_PATH=./data/codemate.db

# --- 缓存（W7 起） ---
REDIS_URL=redis://localhost:6379/0
SEMANTIC_CACHE_THRESHOLD=0.92             # 语义缓存命中阈值

# --- 观测（W7 起） ---
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx

# --- LeetCode（W5 起，可选；仅 submit 需要） ---
LEETCODE_SESSION=                         # 浏览器 cookie 复制
LEETCODE_CSRFTOKEN=
LEETCODE_USE_CN=false                     # true=leetcode.cn，false=leetcode.com

# --- 应用 ---
LOG_LEVEL=INFO
APP_PORT=8000
